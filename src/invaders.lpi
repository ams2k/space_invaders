<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <General>
      <Flags>
        <MainUnitHasCreateFormStatements Value="False"/>
        <MainUnitHasTitleStatement Value="False"/>
        <MainUnitHasScaledStatement Value="False"/>
      </Flags>
      <SessionStorage Value="InProjectDir"/>
      <Title Value="invaders"/>
      <UseAppBundle Value="False"/>
      <ResourceType Value="res"/>
    </General>
    <BuildModes>
      <Item Name="linux" Default="True"/>
    </BuildModes>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
    <RunParams>
      <FormatVersion Value="2"/>
    </RunParams>
    <RequiredPackages>
      <Item>
        <PackageName Value="ray4laz"/>
      </Item>
    </RequiredPackages>
    <Units>
      <Unit>
        <Filename Value="invaders.lpr"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="entities/alien.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="Alien"/>
      </Unit>
      <Unit>
        <Filename Value="entities/block.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="Block"/>
      </Unit>
      <Unit>
        <Filename Value="entities/laser.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="Laser"/>
      </Unit>
      <Unit>
        <Filename Value="entities/mysteryship.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="MysteryShip"/>
      </Unit>
      <Unit>
        <Filename Value="entities/spaceship.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="Spaceship"/>
      </Unit>
      <Unit>
        <Filename Value="entities/obstacle.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="Obstacle"/>
      </Unit>
      <Unit>
        <Filename Value="entities/game.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="Game"/>
      </Unit>
      <Unit>
        <Filename Value="entities/gameutils.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="GameUtils"/>
      </Unit>
      <Unit>
        <Filename Value="entities/constants.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="Constants"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <Target>
      <Filename Value="../release/invaders"/>
    </Target>
    <SearchPaths>
      <IncludeFiles Value="$(ProjOutDir)"/>
      <OtherUnitFiles Value="entities"/>
      <UnitOutputDirectory Value="../temp/$(TargetCPU)-$(TargetOS)"/>
    </SearchPaths>
    <CodeGeneration>
      <TargetCPU Value="x86_64"/>
      <TargetOS Value="linux"/>
    </CodeGeneration>
    <Linking>
      <Debugging>
        <DebugInfoType Value="dsDwarf3"/>
      </Debugging>
    </Linking>
  </CompilerOptions>
  <Debugging>
    <Exceptions>
      <Item>
        <Name Value="EAbort"/>
      </Item>
      <Item>
        <Name Value="ECodetoolError"/>
      </Item>
      <Item>
        <Name Value="EFOpenError"/>
      </Item>
    </Exceptions>
  </Debugging>
</CONFIG>
